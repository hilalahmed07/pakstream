PORT=5001
MONGODB_URI=mongodb://localhost:27017/pakstream
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
ADMIN_REGISTRATION_KEY=admin123
NODE_ENV=development
CORS_ORIGIN=http://10.33.100.70

# LDAP Authentication
# Set LDAP_ENABLED=true to authenticate users against your LDAP/Active Directory server.
# When disabled (default), local password authentication is used.
LDAP_ENABLED=false
LDAP_URL=ldap://your-ldap-server.com
LDAP_BASE_DN=dc=example,dc=com
LDAP_BIND_DN=cn=admin,dc=example,dc=com
LDAP_BIND_PASSWORD=adminPassword
# For Windows Active Directory: (sAMAccountName={{username}})
# For OpenLDAP:                 (uid={{username}})
LDAP_SEARCH_FILTER=(sAMAccountName={{username}})
# LDAP_FALLBACK=true means fall back to local auth if the LDAP server is unreachable
LDAP_FALLBACK=true

# Storage Configuration
# To use local storage, set STORAGE_TYPE=local
# To use MinIO storage, set STORAGE_TYPE=minio
# Local dev: no MinIO required. Set STORAGE_TYPE=minio when MinIO is running.
STORAGE_TYPE=local

# To use MinIO instead:
# STORAGE_TYPE=minio


# MinIO Settings
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=pakstream
MINIO_PUBLIC_URL=http://localhost:9000/pakstream