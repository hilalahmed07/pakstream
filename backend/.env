PORT=5001
MONGODB_URI=mongodb://localhost:27017/pakstream
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
ADMIN_REGISTRATION_KEY=admin123
NODE_ENV=development
CORS_ORIGIN=http://10.33.100.70

# Storage Configuration
# To use local storage, set STORAGE_TYPE=local
# To use MinIO storage, set STORAGE_TYPE=minio
# Local dev: no MinIO required. Set STORAGE_TYPE=minio when MinIO is running.
STORAGE_TYPE=local

# To use MinIO instead:
# STORAGE_TYPE=minio


# MinIO Settings
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=pakstream
MINIO_PUBLIC_URL=http://localhost:9000/pakstream